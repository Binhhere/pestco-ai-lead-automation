generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Service {
  ants
  termites
  rodents
  roaches
  general
}

enum PestType {
  ants
  termites
  rodents
  roaches
  general
}

enum Urgency {
  low
  medium
  high
}

enum Status {
  New
  Contacted
  Qualified
  InspectionScheduled
  Closed
}

model Lead {
  id               String          @id @default(cuid())
  name             String
  phone            String
  email            String
  service          Service
  message          String
  city             String
  preferredTime    String?
  score            Int
  urgency          Urgency
  pestType         PestType
  summary          String
  recommendedReply String
  nextAction       String
  status           Status
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  automationLogs   AutomationLog[]
}

model AutomationLog {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  eventType String
  payload   Json
  createdAt DateTime @default(now())
}
